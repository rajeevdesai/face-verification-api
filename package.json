{
  "name": "@rajeevdesai/face-recognition-api",
  "version": "0.1.0",
  "description": "Browser face verification library — custom pipeline (no wrapper libs)",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Rajeev Desai",
    "url": "https://github.com/rajeevdesai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajeevdesai/face-recognition-api.git"
  },
  "bugs": {
    "url": "https://github.com/rajeevdesai/face-recognition-api/issues"
  },
  "homepage": "https://github.com/rajeevdesai/face-recognition-api#readme",
  "keywords": [
    "face-recognition",
    "face-verification",
    "face-detection",
    "liveness",
    "anti-spoofing",
    "biometrics",
    "arcface",
    "mobilefacenet",
    "onnx",
    "mediapipe",
    "browser",
    "wasm"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "dist/face-recognition-api.umd.cjs",
  "module": "dist/face-recognition-api.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/face-recognition-api.js",
      "require": "./dist/face-recognition-api.umd.cjs"
    }
  },
  "files": [
    "dist",
    "NOTICE",
    "models/download.sh"
  ],
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "dev": "concurrently \"vite build --watch\" \"python3 -m http.server 5299\"",
    "demo": "npm run build && python3 -m http.server 5299",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,ts,js}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.{json,ts,js}\"",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@mediapipe/tasks-vision": ">=0.10.0",
    "onnxruntime-web": ">=1.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mediapipe/tasks-vision": "^0.10.21",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "onnxruntime-web": "^1.20.0",
    "prettier": "^3.8.3",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^1.6.0"
  }
}
